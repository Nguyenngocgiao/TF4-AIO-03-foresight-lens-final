        <mxCell id="title" parent="1" style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=30;fontStyle=1;fontFamily=Helvetica;fontColor=#232F3E;whiteSpace=wrap;" value="TF4 Foresight Lens — AIOps Prediction Pipeline" vertex="1">
