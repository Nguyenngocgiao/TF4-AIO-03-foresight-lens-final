        <mxCell id="subtitle" parent="1" style="text;html=1;resizable=0;points=[];autosize=0;align=left;verticalAlign=top;spacingTop=-4;fontSize=16;fontStyle=0;fontFamily=Helvetica;fontColor=#555555;whiteSpace=wrap;" value="EWMA &amp; STL Decomposition, stateless ECS Fargate, CloudWatch Audit, CDO manual approval. Target: &lt;500ms latency, Zero-cost baseline." vertex="1">
